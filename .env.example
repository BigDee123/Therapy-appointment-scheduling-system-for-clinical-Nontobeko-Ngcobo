# ════════════════════════════════════════════════════════════
#  Nontobeko Ngcobo Booking System — Environment Variables
#  Copy this file to .env and fill in the values
# ════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security keys (REQUIRED — generate strong random values) ─
# Use: https://passwordsgenerator.net — set to 64 chars, all types
JWT_SECRET=REPLACE_WITH_64_RANDOM_CHARACTERS
ENCRYPTION_KEY=REPLACE_WITH_DIFFERENT_64_RANDOM_CHARACTERS

# ── Admin login (REQUIRED) ────────────────────────────────────
ADMIN_EMAIL=nontobeko@simlamedical.co.za
ADMIN_PASSWORD=ChooseAStrongPassword123!
JWT_EXPIRES_IN=8h

# ── Practice details ──────────────────────────────────────────
PRACTICE_NAME=Nontobeko Ngcobo – Clinical Psychologist
PRACTICE_PHONE=0843090111
PRACTICE_ADDRESS=Simla Medical Centre, Belhar, Cape Town
PRACTICE_EMAIL=nontobekorn@gmail.com
INFO_OFFICER_NAME=Nontobeko Ngcobo
INFO_OFFICER_EMAIL=nontobekorn@gmail.com

# ── Email (Gmail recommended — see README Step 3) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
EMAIL_FROM="Nontobeko Ngcobo <your_gmail_address@gmail.com>"

# ── WhatsApp via Twilio (optional — see README Step 4) ────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Calendar (optional — see README Step 5) ────────────
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the full private key from your service account JSON, keep the \n chars:
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----\n"

# ── Supabase database (REQUIRED — replaces JSON file store) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Email via Resend (REQUIRED on Render — SMTP ports are blocked there) ──
# Sign up free at https://resend.com — no credit card needed
# ── Email via SendGrid (RECOMMENDED — free, sends to any recipient instantly) ──
# Sign up free at https://signup.sendgrid.com/ — no domain needed.
# Free tier: 100 emails/day forever. Verify your Gmail as a "Single Sender" first.
SENDGRID_API_KEY=SG.your-api-key-here

# ── Email via Brevo (alternative free option — 300 emails/day) ──
BREVO_API_KEY=xkeysib-your-api-key-here

# ── Email via Resend (alternative — free tier only sends to YOUR OWN email ──
# unless you verify a domain you own. Leave blank if using SendGrid/Brevo above.) ──
RESEND_API_KEY=re_your_api_key_here

# ── Virtual session meeting link (Teams, Zoom, Google Meet — any link works) ──
# Sent automatically in confirmation/reminder emails for virtual bookings.
# For now this is one fixed link; ask Nontobeko for her permanent Teams meeting link.
TEAMS_MEETING_LINK=https://teams.microsoft.com/l/meetup-join/your-permanent-link-here

# ── Invoice / banking details (shown on generated invoices) ──
PRACTICE_HPCSA_NO=0157120
PRACTICE_NUMBER=1196871
PRACTICE_BANK_NAME=Standard Bank
PRACTICE_BANK_ACCOUNT=10117278279
PRACTICE_BANK_ACC_TYPE=Current
PRACTICE_BANK_BRANCH=003326
